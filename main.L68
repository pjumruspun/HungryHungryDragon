0000362E                          4413      
0000362E  202B 3664               4414      MOVE.l  PRNlword(a3),d0     * get current seed longword
00003632  72AF                    4415      MOVEQ       #$AF-$100,d1        * set EOR value
00003634  7412                    4416      MOVEQ       #18,d2          * do this 19 times
00003636                          4417  Ninc0
00003636  D080                    4418      ADD.l       d0,d0               * shift left 1 bit
00003638  6402                    4419      BCC.s       Ninc1               * if bit not set skip feedback
0000363A                          4420  
0000363A  B300                    4421      EOR.b       d1,d0               * do Galois LFSR feedback
0000363C                          4422  Ninc1
0000363C  51CA FFF8               4423      DBF     d2,Ninc0            * loop
00003640                          4424  
00003640  2740 3664               4425      MOVE.l  d0,PRNlword(a3)     * save back to seed longword
00003644                          4426  
00003644  4CD7 0007               4427      movem.l (sp), d0-d2
00003648  DFFC 0000000C           4428      add.l   #LONG_OFFSET*3, sp  ; Load context
